# === Tajné hodnoty — NIKDY necommitovat do gitu ===
# Zkopíruj tento soubor na `.env` a vyplň. V CI (GitHub Actions, Milník 6)
# půjdou stejné hodnoty do GitHub Secrets, ne do repa.

# --- Claude API (scoring, Milník 3) ---
ANTHROPIC_API_KEY=
# Model na scoring (volitelné; default claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- E-mailový digest přes SMTP (Milník 4) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
# Odesílatel a příjemce digestu
DIGEST_FROM=
DIGEST_TO=

# --- Volitelná přepsání konfigurace ---
# Cesta k targets.yaml (default config/targets.yaml)
# TARGETS_PATH=config/targets.yaml
# Přepiš stáří firem ve dnech (jinak se bere z targets.yaml)
# MAX_AGE_DAYS=30
